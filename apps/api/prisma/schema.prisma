generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BoardRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  MOVE
}

enum EntityType {
  BOARD
  LIST
  CARD
  COMMENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String?
  password  String   @default("")
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boards        BoardMember[]
  comments      Comment[]
  activities    Activity[]
  cardLabels    CardAssignee[]
  refreshTokens RefreshToken[]
}

model Board {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  lists       List[]
  members     BoardMember[]
  activities  Activity[]
  webhooks    Webhook[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model BoardMember {
  id      String    @id @default(cuid())
  boardId String
  userId  String
  role    BoardRole @default(MEMBER)
  board   Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model List {
  id        String   @id @default(cuid())
  boardId   String
  title     String
  position  Float
  cards     Card[]
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Card {
  id          String        @id @default(cuid())
  listId      String
  title       String
  description String?
  position    Float
  labels      String[]
  assignees   String[]
  startDate   DateTime?
  dueDate     DateTime?
  coverColor  String?
  archived    Boolean       @default(false)
  checklist   Json?
  attachments Json?
  comments    Comment[]
  cardLabels  CardLabel[]
  cardAssignees CardAssignee[]
  list        List          @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([listId])
}

model CardLabel {
  id     String @id @default(cuid())
  cardId String
  name   String
  color  String @default("#3B82F6")
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model CardAssignee {
  id     String @id @default(cuid())
  cardId String
  userId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([cardId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  content   String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([cardId])
}

model Activity {
  id         String         @id @default(cuid())
  boardId    String
  userId     String
  action     ActivityAction
  entityType EntityType
  entityId   String
  metadata   Json?
  board      Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@index([boardId])
  @@index([userId])
  @@index([createdAt])
}

model Webhook {
  id        String   @id @default(cuid())
  boardId   String
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@index([token])
}
